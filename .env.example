# 环境变量模板


# ---------- OpenAI 兼容 API（可选） ----------
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ---------- 阿里云通义千问 DashScope（可选） ----------
DASHSCOPE_API_KEY=

# ---------- OneAPI 方案 ----------
ONEAPI_API_KEY=
ONEAPI_API_BASE=

# ---------- PostgreSQL（docker-compose 中的配置） ----------
# 启动应用前请确保 PostgreSQL 已运行；若用 Docker，请先启动容器并确保端口映射正确
DB_URI=

# ---------- Docker Compose 启动 Postgres（与 DB_URI 中账号密码保持一致） ----------
POSTGRES_USER=
POSTGRES_PASSWORD=

# ---------- LangSmith 追踪（可选） ----------
# LANGCHAIN_TRACING_V2=
# LANGCHAIN_API_KEY=
