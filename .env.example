# Environment variable template


# ---------- OpenAI-compatible API (optional) ----------
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ---------- Alibaba Cloud Qwen DashScope (optional) ----------
DASHSCOPE_API_KEY=

# ---------- OneAPI setup ----------
ONEAPI_API_KEY=
ONEAPI_API_BASE=

# ---------- PostgreSQL (configuration used in docker-compose) ----------
# Make sure PostgreSQL is running before starting the app; if using Docker, start the container first and verify the port mapping is correct
DB_URI=

# ---------- Docker Compose Postgres startup (keep credentials consistent with DB_URI) ----------
POSTGRES_USER=
POSTGRES_PASSWORD=

# ---------- LangSmith tracing (optional) ----------
# LANGCHAIN_TRACING_V2=
# LANGCHAIN_API_KEY=
